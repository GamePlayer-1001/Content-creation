# ============================================================
#  .gitignore — 内容生成输出项目（重构后）
#  [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md
# ============================================================

# --- Node / Python ---
node_modules/
__pycache__/
*.pyc
.env
*.egg-info/
package-lock.json

# --- 敏感文件（Cookies / 凭证）---
config/xhs_cookies.json

# --- 子项目已清除，以下条目保留防止误添加 ---
Auto-Redbook-Skills/
内容/
CAT5_Brain/
子项目/

# --- videocheck（3.3GB AI视频处理子系统，独立管理）---
videocheck/

# --- 排除目录（参考资料，已提炼入 config/ 和 docs/）---
排除/

# --- 输出产物（大量生成文件，按需 commit）---
output/封面/*.png
output/卡片/*.png
output/卡片/*.html
output/drafts/
output/queue/
output/published/
output/scraper/
output/test_covers/

# --- 工具运行产物 ---
tools/screenshot/.cache/
logs/

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# --- IDE ---
.vscode/
.idea/
*.code-workspace
